# =============================================================================
# onix — Gabarit d'environnement de PRODUCTION (déploiement d'entreprise exposé).
# -----------------------------------------------------------------------------
# Schéma multi-environnement (un fichier .env PAR environnement) :
#
#   env.template            -> .env          (DEV / poste local  : basic, 127.0.0.1)
#   deploy/prod/env.prod.template
#                           -> .env.test     (TEST / pré-prod     : OIDC, IP interne)
#                           -> .env.prod     (PROD                : OIDC, domaine public)
#
# Procédure :
#   cp deploy/prod/env.prod.template deploy/prod/.env.prod   # (ou .env.test)
#   ./scripts/gen-secrets.sh   # génère/complète les SECRETS dans .env (cf. note)
#   # reporter les secrets générés ici, OU pointer vers un coffre (Key Vault)
#   make up-prod ENV=deploy/prod/.env.prod
#
# NOTE secrets : gen-secrets.sh écrit dans `.env` (dev). En production, gérez les
# secrets via un COFFRE (Azure Key Vault, Vault, secrets CI) puis injectez-les
# dans .env.prod / variables d'environnement. Ne committez JAMAIS .env.prod
# (gitignoré : deploy/prod/.env*). Permissions recommandées : chmod 600.
# =============================================================================

# --- Versions épinglées (reproductibilité — identiques à la base) ------------
IMAGE_TAG=4.1.1
OLLAMA_IMAGE_TAG=0.30.8

# Image du microservice onix-actions : ÉPINGLÉE par tag, idéalement par DIGEST.
# Buildée et poussée en CI (coordination WS6 — cf. docs/DEPLOY_PROD.md).
# Exemple (digest = reproductibilité forte) :
#   ACTIONS_IMAGE=ghcr.io/<org>/onix-actions:1.0.0@sha256:<digest_64_hex>
ACTIONS_IMAGE=ghcr.io/CHANGEME-org/onix-actions:1.0.0

# =============================================================================
# EXPOSITION RÉSEAU & TLS  (lus par le garde-fou preflight et par Caddy)
# =============================================================================
# IP/host RÉEL sur lequel Caddy publie 80/443. 0.0.0.0 = toutes interfaces
# (derrière pare-feu). Mettre une IP précise pour restreindre l'interface.
# ⚠ Tout ce qui n'est PAS 127.0.0.1 déclenche l'exigence TLS+OIDC+email (preflight).
BIND_IP=0.0.0.0

# Domaine PUBLIC réel servi par Caddy (certificat Let's Encrypt automatique).
# Doit pointer (DNS A/AAAA) vers BIND_IP et être joignable sur :80 et :443.
ONYX_DOMAIN=onix.exemple.fr

# E-mail de contact ACME (avis d'expiration Let's Encrypt). Obligatoire en prod.
ACME_EMAIL=ops@exemple.fr

# Autorité ACME. Défaut (vide) = Let's Encrypt PRODUCTION. Pour les essais sans
# épuiser le rate-limit : https://acme-staging-v02.api.letsencrypt.org/directory
ACME_CA=https://acme-v02.api.letsencrypt.org/directory

# URL publique de l'app (HTTPS OBLIGATOIRE). Doit valoir https://${ONYX_DOMAIN}.
# Sert de base à l'URL de callback OIDC : https://${ONYX_DOMAIN}/auth/oidc/callback
WEB_DOMAIN=https://onix.exemple.fr

# =============================================================================
# AUTHENTIFICATION — OIDC / Microsoft Entra ID (SSO d'entreprise) — FORCÉ
# =============================================================================
# Le compose prod impose AUTH_TYPE=oidc / REQUIRE_EMAIL_VERIFICATION=true ; ces
# valeurs sont ici pour le garde-fou preflight et la lisibilité.
AUTH_TYPE=oidc

# Enregistrement d'application Entra ID (Azure portal → App registrations) :
#   - Redirect URI (type Web) à déclarer : https://<ONYX_DOMAIN>/auth/oidc/callback
#   - Récupérer Application (client) ID + un Client secret.
OAUTH_CLIENT_ID=CHANGEME-client-id
OAUTH_CLIENT_SECRET=CHANGEME-client-secret

# URL de configuration OpenID du tenant (v2.0). <TENANT> = ID de tenant (GUID)
# ou domaine. Format Entra ID :
OPENID_CONFIG_URL=https://login.microsoftonline.com/CHANGEME-tenant-id/v2.0/.well-known/openid-configuration

# PKCE : recommandé (défense supplémentaire du flux d'autorisation).
OIDC_PKCE_ENABLED=true
# Surcharge éventuelle des scopes (CSV). Vide = scopes par défaut (openid,email,profile).
OIDC_SCOPE_OVERRIDE=

# Vérification d'e-mail + domaines autorisés : ferme la prise de contrôle.
REQUIRE_EMAIL_VERIFICATION=true
# CSV des domaines e-mail autorisés à se connecter (votre organisation).
VALID_EMAIL_DOMAINS=exemple.fr
USER_DIRECTORY_ADMIN_ONLY=true

# Durée de session (s). Prod : 12 h (ré-authentification plus fréquente).
SESSION_EXPIRE_TIME_SECONDS=43200

# Confidentialité : aucune télémétrie sortante.
DISABLE_TELEMETRY=true

# =============================================================================
# PASSERELLE RBAC (access-gateway) + oauth2-proxy — chemin chat sécurisé
# -----------------------------------------------------------------------------
# Topologie (cf. docs/DEPLOY_PROD.md §5bis) : navigateur -> Caddy (TLS +
# forward_auth oauth2-proxy) -> nginx (pose X-OIDC-Claims VÉRIFIÉ, anti-usurpation)
# -> access-gateway (RBAC : Document Set forcé, cache, ACL par-doc, garde-fous,
# streaming, /metrics) -> api_server. SEUL le chemin /api/chat/send-message
# traverse la passerelle ; le reste de l'UI/API garde l'OIDC natif d'Onyx.
# Les secrets associés sont plus bas (section SECRETS). chmod 600 ; coffre en prod.
# =============================================================================

# --- oauth2-proxy : émetteur OIDC du tenant Entra (v2.0). <TENANT> = GUID/domaine.
# Souvent identique à OPENID_CONFIG_URL sans le suffixe /.well-known/...
OAUTH2_PROXY_OIDC_ISSUER_URL=https://login.microsoftonline.com/CHANGEME-tenant-id/v2.0
# Dimensionnement oauth2-proxy (léger).
OAUTH2_PROXY_CPU_LIMIT=1
OAUTH2_PROXY_MEM_LIMIT=256m

# --- access-gateway : source des groupes Entra -------------------------------
# 'graph' (RECOMMANDÉ en prod) : oauth2-proxy fournit l'oid VÉRIFIÉ ; la
# passerelle résout l'appartenance via Microsoft Graph (transitiveMemberOf).
# 'auto'/'claims' : nécessitent un tableau `groups` exploitable dans X-OIDC-Claims
# (NON fourni par le bridge nginx pur — cf. docs/DEPLOY_PROD.md §5bis).
GATEWAY_GROUP_SOURCE=graph
GATEWAY_OIDC_GROUP_CLAIMS=groups,roles

# Microsoft Graph (REQUIS si GATEWAY_GROUP_SOURCE=graph ou repli auto en overage).
# App registration (peut être celle d'oauth2-proxy) avec la permission APPLICATION
# de moindre privilège : GroupMember.Read.All (consentement admin). Le secret va
# dans GATEWAY_GRAPH_CLIENT_SECRET (section SECRETS / coffre).
GATEWAY_GRAPH_TENANT_ID=CHANGEME-tenant-id
GATEWAY_GRAPH_CLIENT_ID=CHANGEME-graph-client-id
# Souverain : adapter pour Gov/China si besoin (sinon laisser les valeurs publiques).
GATEWAY_GRAPH_HOST=https://graph.microsoft.com
GATEWAY_GRAPH_AUTHORITY=https://login.microsoftonline.com

# Clé API Onyx (optionnelle) : vide => la passerelle relaie sans clé (l'autorité
# d'accès EST la passerelle ; Onyx reste interne, sans route publique directe).
GATEWAY_ONYX_API_KEY=

# --- Politique fail-closed (laisser ces valeurs en prod) ---------------------
GATEWAY_DENY_IF_NO_MATCH=true
GATEWAY_GROUP_CACHE_TTL=300
GATEWAY_GUARDRAIL_ENABLED=true
GATEWAY_UPSTREAM_TIMEOUT=30
GATEWAY_METRICS_ENABLED=true

# --- Cache de réponses RBAC-safe (REUTILISE le Redis `cache`, base 1) --------
# docs/CACHE.md. La passerelle compose elle-même l'URL Redis avec REDIS_PASSWORD :
#   redis://:${REDIS_PASSWORD}@cache:6379/1   (base 1 ; Onyx utilise la 0).
# GATEWAY_CACHE_HMAC_SECRET (OBLIGATOIRE si activé) est dans la section SECRETS.
GATEWAY_CACHE_ENABLED=true
GATEWAY_CACHE_TTL_SECONDS=3600
GATEWAY_CACHE_MAX_ENTRIES=512
GATEWAY_CACHE_LOCALE=fr

# --- RBAC fin par DOCUMENT (filtre de SORTIE, FOSS) — cf. docs/RBAC.md -------
# ACTIF seulement si un fichier ACL est monté (sinon INACTIF + avertissement).
# Monter votre doc_acl.json sur /config/doc_acl.json (cf. docker-compose.prod.yml).
GATEWAY_DOC_ACL_ENABLED=true
GATEWAY_DOC_ACL_DEFAULT_POLICY=deny
GATEWAY_DOC_ACL_STRIP_UNCITED=true

# --- Streaming SSE (latence perçue ÷10 sur CPU) — cf. docs/STREAMING.md ------
GATEWAY_STREAM_ENABLED=true
GATEWAY_STREAM_IDLE_TIMEOUT=60

# --- ACL par-document auto-dérivée de SharePoint via Graph (opt-in) ----------
# Nécessite Graph configuré + un mapping doc->item monté sur /config/doc_acl_mapping.json.
GATEWAY_DOC_ACL_GRAPH_ENABLED=false
GATEWAY_DOC_ACL_REFRESH_SECONDS=900

GATEWAY_LOG_LEVEL=INFO

# Dimensionnement de la passerelle (proxy léger ; voir aussi section sizing).
GATEWAY_CPU_LIMIT=1
GATEWAY_MEM_LIMIT=512m

# =============================================================================
# SECRETS (générés par scripts/gen-secrets.sh — NE JAMAIS committer .env.prod)
# =============================================================================
# En prod, préférez un COFFRE (Key Vault) : injectez ces valeurs depuis le coffre
# au déploiement plutôt que de les stocker en clair ici.
SECRET=
USER_AUTH_SECRET=
# Chiffrement AU REPOS des secrets connecteurs/LLM/OAuth Onyx. CRITIQUE en prod :
# si VIDE, Onyx les écrit EN CLAIR dans Postgres SANS erreur au boot. Généré par
# gen-secrets.sh (cf. SECURITY.md:33). En prod, injecter depuis le coffre.
ENCRYPTION_KEY_SECRET=
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
DB_READONLY_USER=db_readonly_user
DB_READONLY_PASSWORD=
OPENSEARCH_ADMIN_PASSWORD=
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
S3_AWS_ACCESS_KEY_ID=
S3_AWS_SECRET_ACCESS_KEY=
REDIS_PASSWORD=
ONIX_ACTIONS_API_KEY=

# --- Secrets de la PASSERELLE RBAC (access-gateway) & d'oauth2-proxy ----------
# Générés par scripts/gen-secrets.sh (cf. `make secrets-gateway` qui produit
# GATEWAY_CACHE_HMAC_SECRET + GATEWAY_AUDIT_SALT dans access-gateway/.env ;
# RECOPIEZ-les ici, ou injectez-les depuis le coffre). NE JAMAIS committer.
#   GATEWAY_CACHE_HMAC_SECRET : OBLIGATOIRE si le cache est activé (>=32 octets
#     aléatoires, STABLE entre redémarrages — sinon le cache se désactive au
#     démarrage avec un log CRITICAL).  openssl rand -hex 32
#   GATEWAY_AUDIT_SALT        : sel HMAC de pseudonymisation du journal d'accès
#     (RGPD : aucun UPN/oid en clair).  openssl rand -hex 32
GATEWAY_CACHE_HMAC_SECRET=
GATEWAY_AUDIT_SALT=
# --- ANTI-SPOOF X-OIDC-Claims (preuve de transit par le proxy, M7) -----------
# OBLIGATOIRE en prod. Secret partagé entre le nginx interne (qui l'injecte dans
# X-OIDC-Proxy-Secret) et la passerelle (qui le compare en temps constant). Sans
# lui, un client atteignant la passerelle EN DIRECT pourrait forger X-OIDC-Claims
# (oid + groupes admin) et usurper une identité = bypass RBAC TOTAL. Fail-closed :
# si VIDE, la passerelle refuse tout X-OIDC-Claims (sauf override dev explicite
# GATEWAY_ALLOW_UNAUTHENTICATED_HEADER=true — JAMAIS en prod). Générer (>=32 octets
# aléatoires, STABLE) :  openssl rand -hex 32
GATEWAY_PROXY_SHARED_SECRET=
# Secret client Microsoft Graph (app-only, permission GroupMember.Read.All).
# Requis si GATEWAY_GROUP_SOURCE=graph (défaut) ou repli auto en cas d'overage.
GATEWAY_GRAPH_CLIENT_SECRET=
# oauth2-proxy : clé de chiffrement du cookie de session (EXACTEMENT 16/24/32
# octets). Générer p.ex. :  openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=
# App registration Entra DÉDIÉE à oauth2-proxy (distincte de celle d'Onyx) :
#   Redirect URI (type Web) à déclarer : https://<ONYX_DOMAIN>/oauth2/callback
OAUTH2_PROXY_CLIENT_ID=CHANGEME-oauth2proxy-client-id
OAUTH2_PROXY_CLIENT_SECRET=CHANGEME-oauth2proxy-client-secret

# =============================================================================
# onix-actions — gouvernance applicative (cf. docs/ACTIONS.md). Prod : kill-switch
# global actif, budget FinOps optionnel, webhook de notification interne.
# =============================================================================
ONIX_RATE_CARD=
ONIX_BUDGET_EUR=
ONIX_BUDGET_WARN_PCT=80
ONIX_GLOBAL_ENABLED=true
ONIX_AUDIT_ENABLED=true
ONIX_GENERATE_ENABLED=true
ONIX_TASKS_ENABLED=true
ONIX_NOTIFY_ENABLED=true
ONIX_USAGE_ENABLED=true
ONIX_COST_ENABLED=true
ONIX_OCR_ENABLED=true
ONIX_LLM_ENABLED=true
ONIX_OLLAMA_URL=http://ollama:11434
ONIX_LLM_MODEL=llama3.2:3b
ONIX_NOTIFY_WEBHOOK=
ONIX_OCR_LANG=fra+eng
ONIX_LOG_LEVEL=INFO

# =============================================================================
# Dimensionnement (PRODUCTION — serveur dédié, à ajuster selon la machine).
# Valeurs plus généreuses que le profil 16 Go local. `make tune` peut aider.
# =============================================================================
OPENSEARCH_HEAP=4g
OPENSEARCH_MEM_LIMIT=8g
INFERENCE_MEM_LIMIT=4g
API_SERVER_MEM_LIMIT=3g
BACKGROUND_MEM_LIMIT=5g
WEB_MEM_LIMIT=1g
POSTGRES_MEM_LIMIT=2g
MINIO_MEM_LIMIT=1g
OLLAMA_MEM_LIMIT=8g
OLLAMA_CPU_LIMIT=8
NGINX_MEM_LIMIT=256m
ACTIONS_MEM_LIMIT=512m
ACTIONS_CPU_LIMIT=1
CADDY_MEM_LIMIT=256m
CADDY_CPU_LIMIT=1
LOG_LEVEL=info

# --- Ollama (production) -----------------------------------------------------
OLLAMA_KEEP_ALIVE=-1
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_QUEUE=512
OLLAMA_FLASH_ATTENTION=1
OLLAMA_KV_CACHE_TYPE=q8_0
OLLAMA_MODELS_TO_PULL=qwen2.5:7b-instruct nomic-embed-text
