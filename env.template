# =============================================================================
# onix — Stack IA privée (Onyx + Ollama) — gabarit d'environnement.
#
#   1. Copiez ce fichier en ".env"  :  cp env.template .env
#   2. Générez les secrets forts     :  ./scripts/gen-secrets.sh   (ou make secrets)
#   3. Démarrez                       :  make up
#
# ".env" est GITIGNORÉ : ne committez JAMAIS de secret réel.
# Les variables marquées (SECRET — généré) sont remplies par gen-secrets.sh.
# =============================================================================

# --- Versions épinglées (reproductibilité) ----------------------------------
IMAGE_TAG=4.1.1
OLLAMA_IMAGE_TAG=0.30.8

# --- Accès & authentification -----------------------------------------------
# Profil retenu : poste local. Onyx n'écoute que sur 127.0.0.1:${ONYX_HOST_PORT}.
ONYX_HOST_PORT=3000
WEB_DOMAIN=http://localhost:3000

# Authentification : disabled | basic | google_oauth | oidc | saml
# 'basic' = comptes locaux email/mot de passe. Le PREMIER compte créé est admin.
AUTH_TYPE=basic

# Durée de session (secondes) avant ré-authentification. Défaut : 24 h.
SESSION_EXPIRE_TIME_SECONDS=86400

# Restreindre l'énumération des comptes aux admins (durcissement). true recommandé.
USER_DIRECTORY_ADMIN_ONLY=true

# Vérification d'email pour l'auth 'basic'. Laisser false en local (pas de SMTP).
# Pour l'activer : REQUIRE_EMAIL_VERIFICATION=true + variables SMTP_* (cf. SECURITY.md).
REQUIRE_EMAIL_VERIFICATION=false

# Restreindre les domaines email autorisés (ex: votre-domaine.com). Vide = aucun filtre.
VALID_EMAIL_DOMAINS=

# Confidentialité : aucune télémétrie sortante.
DISABLE_TELEMETRY=true

# --- Secrets (générés par scripts/gen-secrets.sh — NE PAS committer) ---------
# Clé de chiffrement applicative Onyx.
SECRET=
# Clé de signature des tokens (reset mot de passe, vérif email, état OAuth). Obligatoire.
USER_AUTH_SECRET=
# Postgres (compte applicatif + compte lecture seule).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
DB_READONLY_USER=db_readonly_user
DB_READONLY_PASSWORD=
# OpenSearch (mot de passe admin — doit respecter la complexité OpenSearch).
OPENSEARCH_ADMIN_PASSWORD=
# MinIO (stockage objet) + identifiants S3 utilisés par Onyx (mêmes valeurs).
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
S3_AWS_ACCESS_KEY_ID=
S3_AWS_SECRET_ACCESS_KEY=
# Redis (cache) — mot de passe (--requirepass). Honoré par Onyx (REDIS_PASSWORD).
REDIS_PASSWORD=
# Clé API du microservice onix-actions (SECRET — généré). Obligatoire : sans
# elle, le service refuse toute requête. Onyx s'authentifie via l'en-tête
# X-API-Key lors de l'appel des Custom Actions (cf. docs/ACTIONS.md).
ONIX_ACTIONS_API_KEY=

# --- onix-actions — couche applicative locale (cf. docs/ACTIONS.md) ----------
# Service interne (réseau onix-net, AUCUN port hôte) : audit OCR, génération
# .docx, tâches, notification, usage, coût, administration. 100 % local.
#
# FinOps : rate card JSON (€/unité) + budget + seuil d'alerte (%). Local-first :
# tout est à 0 € par défaut ; valorisez l'électricité / l'amortissement si voulu.
# Centres de coût : llm_message, llm_token_input, llm_token_output, ocr_page,
#   audit_request, fiche_generation, notification, storage, compute_hour.
ONIX_RATE_CARD=
ONIX_BUDGET_EUR=
ONIX_BUDGET_WARN_PCT=80
# Kill-switch global + flags par fonction. true = activé. Mettre false (ou le
# basculer à chaud via POST /admin/control) COUPE réellement l'endpoint (403).
ONIX_GLOBAL_ENABLED=true
ONIX_AUDIT_ENABLED=true
ONIX_GENERATE_ENABLED=true
ONIX_TASKS_ENABLED=true
ONIX_NOTIFY_ENABLED=true
ONIX_USAGE_ENABLED=true
ONIX_COST_ENABLED=true
ONIX_OCR_ENABLED=true
ONIX_LLM_ENABLED=true
# Assistance LLM locale (extraction de champs depuis un texte brut) via Ollama.
ONIX_OLLAMA_URL=http://ollama:11434
ONIX_LLM_MODEL=llama3.2:3b
# Timeouts LLM (secondes) : connexion courte (détecte vite un Ollama absent) +
# lecture plus longue (génération). Repli heuristique propre si dépassement.
ONIX_LLM_CONNECT_TIMEOUT=5
ONIX_LLM_TIMEOUT=60
# Notification générique : URL de webhook (Slack/Mattermost/Teams-compatible).
# Pour l'email, renseigner ONIX_SMTP_HOST/PORT/USER/PASSWORD/FROM/TO (cf. ACTIONS.md).
ONIX_NOTIFY_WEBHOOK=
# Timeout d'envoi webhook (s). En cas de cible injoignable : statut 'error' propre.
ONIX_NOTIFY_TIMEOUT=15
# SMTP : STARTTLS activé par défaut. Pour un relais interne EN CLAIR (sans TLS),
# mettre ONIX_SMTP_STARTTLS=false. ONIX_SMTP_SSL=true pour du SMTPS direct.
ONIX_SMTP_STARTTLS=true
ONIX_SMTP_TIMEOUT=20
# Niveau de log applicatif (DEBUG/INFO/WARNING…) : trace le mode d'extraction
# réellement utilisé (llm vs heuristique) et les échecs notify.
ONIX_LOG_LEVEL=INFO
# Langues OCR (paquets tesseract installés dans l'image : fra + eng).
ONIX_OCR_LANG=fra+eng

# --- Ollama (LLM local) — `make tune` remplit ces valeurs au plus juste -------
# KEEP_ALIVE : durée de maintien en mémoire. 5m = libère la RAM à l'inactivité ;
#   -1 = toujours chargé (zéro latence). `make tune` ne met -1 que si RAM >= ~24 Go
#   (sur 16 Go, épingler un modèle en permanence rapproche de l'OOM → 5m).
# MAX_LOADED_MODELS / NUM_PARALLEL : coût RAM (passent à 2 si RAM utile >= ~12 Go).
OLLAMA_KEEP_ALIVE=5m
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_QUEUE=512
# Perf (cf. docs/PERFORMANCE.md) : Flash Attention + cache KV quantifié q8_0
# → -30 à -50% de mémoire de contexte, quasi sans perte de qualité.
OLLAMA_FLASH_ATTENTION=1
OLLAMA_KV_CACHE_TYPE=q8_0
# Fenêtre de contexte (num_ctx) par défaut du serveur Ollama. Le défaut Ollama
# (4096) est TROP COURT et tronque silencieusement le contexte RAG (mesuré sur
# CPU : prompt 3000 tok → ~2035 ingérés avec le défaut + NUM_PARALLEL=2). On
# l'élargit. RÈGLE MÉMOIRE : la KV-cache croît avec
# OLLAMA_CONTEXT_LENGTH × OLLAMA_NUM_PARALLEL (q8_0 ci-dessus la ~divise par 2 ;
# source : Ollama FAQ « NUM_PARALLEL scales RAM requirements »). `make tune` fixe
# 8192 (≤3B) / 12288 (7-8B) / 16384 (GPU). Mono-utilisateur : gardez NUM_PARALLEL=1
# pour le contexte maximal par requête. Détail : docs/PERFORMANCE.md §2bis.
OLLAMA_CONTEXT_LENGTH=8192
# Modèles à pré-tirer (séparés par des espaces). `make tune` choisit le plus gros
# modèle qui TIENT dans la RAM libre (RAM - réserve OS - baseline Onyx ~7 Go), ou
# dans la VRAM en GPU. Source de vérité unique : scripts/detect-hardware.sh.
# Seuils retenus (identiques .sh / .ps1) — RAM libre pour Ollama / VRAM :
#   CPU  <4 Go     : "llama3.2:1b"          (postes très contraints)
#   CPU  4-6 Go    : "llama3.2:3b"          (≈ 16 Go RAM physique — prudent)
#   CPU  7-17 Go   : "qwen2.5:7b-instruct"  (≈ 24 Go RAM physique)
#   CPU  >=18 Go   : "qwen2.5:14b-instruct" (>= 32 Go ; plafonné à 14B en CPU)
#   GPU  VRAM>=8/12/24 : llama3.1:8b / qwen2.5:14b / qwen2.5:32b
# NB `nomic-embed-text` : tiré pour des usages Ollama-NATIFS (juge d'éval RAGAS,
# outils tiers). Onyx N'EMBED PAS via Ollama (il a son propre model-server) — vous
# pouvez le retirer de la liste si vous n'appelez pas Ollama pour de l'embedding.
OLLAMA_MODELS_TO_PULL=llama3.2:3b nomic-embed-text

# --- Qualité RAG côté Onyx (optionnel) — voir docs/PLAYBOOK_ONYX_RAG.md --------
# Transmises à Onyx via env_file (.env). LAISSÉES COMMENTÉES = défauts Onyx
# (non-cassant). À activer pour un corpus FRANÇAIS — nécessite un RÉ-INDEX (faites
# embedder + analyseur ENSEMBLE). Procédure pas-à-pas : docs/PLAYBOOK_ONYX_RAG.md.
#   Analyseur lexical BM25 : 'french' active le stemming FR (défaut 'english').
# OPENSEARCH_TEXT_ANALYZER=french
#   Nb max de chunks injectés au LLM/réponse. 8 (avec reranker) évite de saturer
#   le contexte (défaut Onyx 25 × 512 tok ≈ 12,8k tok). Commenté = défaut Onyx.
# MAX_CHUNKS_FED_TO_CHAT=8

# --- Dimensionnement ressources (défaut PRUDENT calibré ~16 Go RAM, CPU) -----
# `make tune` (scripts/detect-hardware.sh) recalcule ces limites au plus juste et
# GARANTIT que leur SOMME reste < RAM physique (anti-OOM). Les valeurs ci-dessous
# sont le profil 16 Go : leur somme (≈ 15 Go + redis) tient sous 16 Go.
OPENSEARCH_HEAP=1g
OPENSEARCH_MEM_LIMIT=2g
INFERENCE_MEM_LIMIT=1792m
API_SERVER_MEM_LIMIT=1g
BACKGROUND_MEM_LIMIT=1792m
WEB_MEM_LIMIT=1g
POSTGRES_MEM_LIMIT=1g
MINIO_MEM_LIMIT=512m
OLLAMA_MEM_LIMIT=5g
OLLAMA_CPU_LIMIT=4
NGINX_MEM_LIMIT=256m
# onix-actions : microservice léger (FastAPI + OCR à la demande).
ACTIONS_MEM_LIMIT=512m
ACTIONS_CPU_LIMIT=1

# --- Avancé (laisser vide en local) -----------------------------------------
LOG_LEVEL=info

# --- WS6 : observabilité -----------------------------------------------------
# Stack de supervision OPTIONNELLE (monitoring/docker-compose.monitoring.yml) :
# Prometheus + Alertmanager + Grafana + Loki/Promtail + exporters. 100 % local,
# images épinglées, aucune télémétrie sortante. Démarrage : make monitor-up.
#
# Grafana : SEUL service exposé, lié à 127.0.0.1 (comme nginx). Port hôte + creds.
# RENSEIGNEZ un mot de passe fort AVANT make monitor-up (sinon 'admin' par défaut).
# Intégration : ajouter `ensure GRAFANA_ADMIN_PASSWORD rand 32` à gen-secrets.sh
# pour le générer automatiquement comme les autres secrets (cf. OBSERVABILITY.md).
GRAFANA_HOST_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
# Alertmanager : URL de webhook SORTANTE optionnelle pour notifier les alertes
# (budget dépassé, service down…). Même convention que ONIX_NOTIFY_WEBHOOK.
# Vide = aucune notification sortante (récepteur local par défaut).
ALERT_WEBHOOK_URL=
# DÉPENDANCE WS2 : Prometheus scrape onix-actions sur http://actions:8100/metrics.
# Cet endpoint /metrics (format texte Prometheus) doit être ajouté au microservice
# actions (cf. docs/OBSERVABILITY.md). Tant qu'il n'existe pas, seul ce job de
# scrape est « down » ; toute la supervision infra + sondes /health fonctionne.

# --- WS2 : sécurité/RGPD -----------------------------------------------------
# Couche sécurité applicative & conformité RGPD d'onix-actions.
# Détails et procédures : docs/SECURITY_RGPD_ACTIONS.md.
#
# Clé ADMIN distincte (en-tête X-Admin-Key) pour /admin/* — SECRET (généré).
# OBLIGATOIRE par défaut (fail-closed) : sans elle, /admin/* renvoie 403. Pour
# l'ancien comportement (clé de service = admin), mettre
# ONIX_ACTIONS_ADMIN_KEY_OPTIONAL=true (déconseillé).
ONIX_ACTIONS_ADMIN_KEY=
ONIX_ACTIONS_ADMIN_KEY_OPTIONAL=false
#
# Identité d'appelant VÉRIFIÉE (qui appelle, pas seulement « appel autorisé ») :
#  - HMAC par appel (souverain, sans dépendance) : en-têtes X-Onix-Caller /
#    X-Onix-Timestamp / X-Onix-Signature signés avec le secret ci-dessous ;
#  - ou JWT OIDC (Authorization: Bearer) — voir variables OIDC plus bas.
# Secret HMAC d'identité d'appelant — SECRET (généré).
ONIX_ACTIONS_CALLER_HMAC_SECRET=
# Fenêtre anti-rejeu de la signature HMAC (secondes).
ONIX_HMAC_MAX_SKEW=300
# Exiger une identité vérifiée (fail-closed) sur les endpoints métier. false par
# défaut (compat clé de service seule) ; true recommandé en multi-utilisateur.
ONIX_ACTIONS_REQUIRE_CALLER_IDENTITY=false
# JWT OIDC (optionnel, ex. Entra ID). HS256 géré nativement ; RS256/ES256 via
# JWKS nécessite PyJWT (présent dans requirements). Laisser vide pour HMAC seul.
ONIX_OIDC_ISSUER=
ONIX_OIDC_AUDIENCE=
ONIX_OIDC_JWKS_URL=
# Secret partagé pour des JWT HS256 (sans JWKS). Laisser vide sinon.
ONIX_OIDC_HS256_SECRET=
#
# Rate-limiting PAR APPELANT (parité quota AC360). Format « N/minute|second|hour ».
# Vide ou 0 -> désactivé.
ONIX_ACTIONS_RATE_LIMIT=60/minute
#
# Journal d'audit admin CHAÎNÉ (tamper-evident) — clé HMAC, SECRET (généré).
# Absente -> repli SHA-256 (toujours détecteur d'altération, garantie réduite).
ONIX_ACTIONS_AUDIT_HMAC_KEY=
#
# DLP egress : destinations SORTANTES autorisées pour /notify (webhook) et
# /tasks(webhook_url). Hôtes/domaines séparés par des virgules ; « *.corp.local »
# autorise les sous-domaines. VIDE + fail-closed (défaut) -> tout egress refusé.
ONIX_EGRESS_ALLOWLIST=
# Politique si allowlist vide : true = refuser tout egress (recommandé).
ONIX_EGRESS_DEFAULT_DENY=true
# Autoriser http:// en sortie (relais interne en clair assumé). Défaut: https only.
ONIX_EGRESS_ALLOW_HTTP=false
# Autoriser une cible sur IP privée/loopback (anti-SSRF). Défaut: refusé sauf si
# l'hôte est explicitement allowlisté (ex. Mattermost interne).
ONIX_EGRESS_ALLOW_PRIVATE_IP=false
#
# Rétention RGPD (art. 5-1-e) : durée de conservation (jours) pour la purge par
# âge (POST /admin/retention/purge) — usage, tâches terminées, .docx générés.
ONIX_RETENTION_DAYS=365
