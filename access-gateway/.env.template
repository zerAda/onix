# access-gateway — gabarit de configuration. COPIER en .env (gitignoré) et remplir.
# Aucun secret réel ici. Le .env est chmod 600 et JAMAIS committé.

# --- Onyx amont (cible du proxy) ---
GATEWAY_ONYX_BASE_URL=http://api_server:8080
# Clé d'API Onyx (Admin -> API Keys). Vide si vous relayez le cookie de session.
GATEWAY_ONYX_API_KEY=

# --- Source des groupes Entra : claims | graph | auto (recommandé) ---
GATEWAY_GROUP_SOURCE=auto
# Claims OIDC porteurs des groupes (ordre = priorité). 'groups' = GUID Entra.
GATEWAY_OIDC_GROUP_CLAIMS=groups,roles

# --- Microsoft Graph (requis si source=graph, ou repli auto en cas d'overage) ---
GATEWAY_GRAPH_TENANT_ID=
GATEWAY_GRAPH_CLIENT_ID=
GATEWAY_GRAPH_CLIENT_SECRET=
# Souverain : adapter pour Gov/China si besoin (sinon laisser les valeurs publiques).
GATEWAY_GRAPH_HOST=https://graph.microsoft.com
GATEWAY_GRAPH_AUTHORITY=https://login.microsoftonline.com

# --- Mapping groupe -> Document Set ---
GATEWAY_MAPPING_PATH=/config/group_map.json

# --- Politique ---
# True : utilisateur sans groupe mappé => REFUSÉ (deny-by-default). Recommandé.
# Laisser à 'true' en production : fail-closed (cf. README "Durcissement").
GATEWAY_DENY_IF_NO_MATCH=true
# TTL (s) du cache des groupes résolus par utilisateur (0 = pas de cache).
GATEWAY_GROUP_CACHE_TTL=300

# --- Audit des décisions d'accès (identité HACHÉE) ---
# Sel HMAC pour pseudonymiser l'identité dans le journal d'accès (RGPD : pas d'UPN
# en clair). FIXER une valeur depuis le coffre pour corréler les événements dans la
# durée (entre redémarrages). Absent => sel aléatoire par processus.
GATEWAY_AUDIT_SALT=

# --- Garde-fous, métriques, timeout amont ---
# Post-filtre garde-fous (couche 3 déterministe) sur la réponse Onyx. Laisser true.
GATEWAY_GUARDRAIL_ENABLED=true
# Endpoint Prometheus GET /metrics (qualité + ops). true par défaut.
GATEWAY_METRICS_ENABLED=true
# Timeout (s) du relais HTTP vers Onyx (génération LLM lente possible en CPU).
GATEWAY_UPSTREAM_TIMEOUT=30

# --- Cache de réponses RBAC-safe (coût tokens + latence) — cf. docs/CACHE.md ---
# Couche déterministe au-dessus d'Onyx/Ollama : une question identique dans le
# MÊME périmètre Document Set ne rappelle plus le LLM. Clé HMAC = périmètre TRIÉ →
# aucune fuite inter-utilisateur. Le filtre ACL par-doc est ré-appliqué APRÈS le
# cache (jamais mutualisé entre utilisateurs).
GATEWAY_CACHE_ENABLED=true
# OBLIGATOIRE si cache activé (>= 32 octets aléatoires, depuis le coffre). SANS
# secret stable, le cache se DÉSACTIVE au démarrage (log CRITICAL) — jamais de sel
# éphémère (casserait l'isolation entre redémarrages). Générer p.ex. :
#   openssl rand -hex 32
GATEWAY_CACHE_HMAC_SECRET=
# Backend : vide = LRU mémoire (process-local) ; en HA multi-réplica, pointer un
# Redis partagé, ex. redis://:motdepasse@cache:6379/1 (sinon le hit-rate s'effondre).
GATEWAY_CACHE_REDIS_URL=
# TTL d'une entrée (s) et bornage de la LRU mémoire.
GATEWAY_CACHE_TTL_SECONDS=3600
GATEWAY_CACHE_MAX_ENTRIES=512
# Locale incluse dans la clé (sépare versions FR/EN d'une même question).
GATEWAY_CACHE_LOCALE=fr

# --- RBAC fin par DOCUMENT (filtre de SORTIE, FOSS) — cf. docs/RBAC.md ---------
# Retire des réponses les citations vers des documents non autorisés pour
# l'appelant (au-delà du cloisonnement par Document Set). ACTIF uniquement si le
# fichier ACL existe (sinon INACTIF + avertissement — un deny-all serait une panne).
GATEWAY_DOC_ACL_ENABLED=true
# Fichier ACL JSON : { "doc_id": {"groups": ["G1"], "users": ["upn"]} }.
# Exemple commenté : access-gateway/config/doc_acl.example.json(.md).
GATEWAY_DOC_ACL_PATH=/config/doc_acl.json
# Politique pour un doc NON listé : deny (défaut, deny-by-default) | allow.
GATEWAY_DOC_ACL_DEFAULT_POLICY=deny
# Si toutes les citations sont retirées : substituer un refus « pas de source
# accessible » (true) plutôt que renvoyer une réponse sans source.
GATEWAY_DOC_ACL_STRIP_UNCITED=true

GATEWAY_LOG_LEVEL=INFO
