# access-gateway — gabarit de configuration. COPIER en .env (gitignoré) et remplir.
# Aucun secret réel ici. Le .env est chmod 600 et JAMAIS committé.

# --- Onyx amont (cible du proxy) ---
GATEWAY_ONYX_BASE_URL=http://api_server:8080
# Clé d'API Onyx (Admin -> API Keys). Vide si vous relayez le cookie de session.
GATEWAY_ONYX_API_KEY=

# --- Source des groupes Entra : claims | graph | auto (recommandé) ---
GATEWAY_GROUP_SOURCE=auto
# Claims OIDC porteurs des groupes (ordre = priorité). 'groups' = GUID Entra.
GATEWAY_OIDC_GROUP_CLAIMS=groups,roles

# --- Microsoft Graph (requis si source=graph, ou repli auto en cas d'overage) ---
GATEWAY_GRAPH_TENANT_ID=
GATEWAY_GRAPH_CLIENT_ID=
GATEWAY_GRAPH_CLIENT_SECRET=
# Souverain : adapter pour Gov/China si besoin (sinon laisser les valeurs publiques).
GATEWAY_GRAPH_HOST=https://graph.microsoft.com
GATEWAY_GRAPH_AUTHORITY=https://login.microsoftonline.com

# --- Mapping groupe -> Document Set ---
GATEWAY_MAPPING_PATH=/config/group_map.json

# --- Politique ---
# True : utilisateur sans groupe mappé => REFUSÉ (deny-by-default). Recommandé.
GATEWAY_DENY_IF_NO_MATCH=true
# TTL (s) du cache des groupes résolus par utilisateur (0 = pas de cache).
GATEWAY_GROUP_CACHE_TTL=300

GATEWAY_LOG_LEVEL=INFO
